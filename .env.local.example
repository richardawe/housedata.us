# Copy to .env.local and fill in values before running

DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...

NEXT_PUBLIC_BASE_URL=https://housedata.us

PACKET_PRICE_USD=49
LAUNCH_COUNTY=travis-tx

# Absolute path on the server where generated PDFs are written.
# The directory must exist and be writable by the Node.js process.
PACKET_STORAGE_PATH=/home/username/packets

# Basic auth password for /admin/orders
ADMIN_PASSWORD=changeme

# Set to true after the protest deadline passes to suppress paid CTAs
DEADLINE_PASSED=false
